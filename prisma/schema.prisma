generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int           @id @default(autoincrement())
  email     String        @unique
  password  String
  firstName String
  lastName  String
  name      String?
  bio       String?
  profileImage String?
  role      Role          @default(INSTRUCTOR)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  courses   Course[]
  contents  SRCHContent[] @relation("UserContents")
  forumPosts    ForumPost[] @relation("UserForumPosts")
  forumComments ForumComment[] @relation("UserForumComments")
  forumVotes    ForumVote[]   @relation("UserForumVotes")
}

model Course {
  id           Int                 @id @default(autoincrement())
  title        String
  code         String?
  description  String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  ownerId      Int
  topic        String?
  subtopic     String?
  propTopic    String?
  propSubtopic String?
  owner        User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  objectives   LearningObjective[]
}

model LearningObjective {
  id          Int                   @id @default(autoincrement())
  description String
  bloomLevel  BloomLevel
  position    Int?
  courseId    Int
  course      Course                @relation(fields: [courseId], references: [id], onDelete: Cascade)
  mappings    ObjectiveContentMap[]
  forumPosts  ForumPost[]
}

model SRCHContent {
  id        Int                   @id @default(autoincrement())
  title     String
  summary   String?
  body      String
  topic     String?
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  authorId  Int?
  mappings  ObjectiveContentMap[]
  author    User?                 @relation( "UserContents", fields: [authorId], references: [id])
}

model ObjectiveContentMap {
  id                  Int               @id @default(autoincrement())
  alignmentNote       String?
  isSelected          Boolean           @default(false)
  createdAt           DateTime          @default(now())
  learningObjectiveId Int
  srchContentId       Int
  learningObjective   LearningObjective @relation(fields: [learningObjectiveId], references: [id], onDelete: Cascade)
  srchContent         SRCHContent       @relation(fields: [srchContentId], references: [id], onDelete: Cascade)

  @@unique([learningObjectiveId, srchContentId])
}

enum Role {
  USER
  ADMIN
  INSTRUCTOR
  EDITOR
}

enum BloomLevel {
  REMEMBER
  UNDERSTAND
  APPLY
  ANALYZE
  EVALUATE
  CREATE
}

model ForumPost {
  id          Int           @id @default(autoincrement())
  title       String
  description String
  bloomLevel  BloomLevel?
  status      ForumStatus   @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  authorId    Int
  author      User          @relation("UserForumPosts", fields: [authorId], references: [id], onDelete: Cascade)
  comments    ForumComment[]
  votes       ForumVote[]
 
  mappedObjectiveId Int?
  mappedObjective   LearningObjective?    @relation(fields: [mappedObjectiveId], references: [id])
}

model ForumComment {
  id        Int       @id @default(autoincrement())
  body      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  authorId  Int
  postId    Int
  author    User      @relation("UserForumComments", fields: [authorId], references: [id], onDelete: Cascade)
  post      ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model ForumVote {
  id        Int       @id @default(autoincrement())
  authorId  Int
  postId    Int
  author    User      @relation("UserForumVotes", fields: [authorId], references: [id], onDelete: Cascade)
  post      ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([authorId, postId]) 
}

enum ForumStatus {
  PENDING   
  MAPPED    
  REJECTED 
}
